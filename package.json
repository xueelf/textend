{
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "bun ./index.html --port=1420",
    "build": "tsc && bun build ./index.html --outdir dist --minify",
    "tauri": "tauri",
    "format": "prettier **/*.ts --write",
    "lint": "eslint **/*.ts",
    "prepare": "husky",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@preact/signals": "^2.9.2",
    "@tabler/icons": "^3.44.0",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "~2.7.1",
    "@tauri-apps/plugin-fs": "~2.5.1",
    "codemirror": "^6.0.2",
    "preact": "^10.29.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/types": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.3",
    "@types/bun": "^1.3.14",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "prettier-plugin-sort": "^0.2.0",
    "typescript-eslint": "^8.61.1"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "devEngines": {
    "runtime": {
      "name": "bun",
      "onFail": "error"
    },
    "packageManager": {
      "name": "bun",
      "onFail": "error"
    }
  }
}
