    "test": "bun test scripts/test/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@commitlint/types": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "prettier-plugin-sort": "^0.1.1",
    "typescript-eslint": "^8.59.3"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "devEngines": {
    "runtime": {
      "name": "bun",
      "onFail": "error"
